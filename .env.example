# ====================== BETTAFISH GENERAL ======================
# BETTAFISH host address, e.g.: 0.0.0.0 or 127.0.0.1
HOST=0.0.0.0
# BETTAFISH port, default is 5000
PORT=5000

# ====================== DATABASE CONFIGURATION ======================
# Database host, e.g. localhost or 127.0.0.1
DB_HOST=your_db_host
# Database port, default is 3306
DB_PORT=3306
# Database username
DB_USER=your_db_user
# Database password
DB_PASSWORD=your_db_password
# Database name
DB_NAME=your_db_name
# Database charset, utf8mb4 recommended for emoji support
DB_CHARSET=utf8mb4
# Database type: mysql or postgresql
DB_DIALECT=postgresql

# ======================= LLM CONFIGURATION =======================
# You can change the API used by each section's LLM. 🚩 Any API compatible with the OpenAI request format is supported — just set KEY, BASE_URL, and MODEL_NAME.
# Important: We strongly recommend using the recommended configuration to obtain an API key and verify it works before making changes!
# Our LLM model API sponsor: https://aihubmix.com/?aff=8Ds9 — provides a comprehensive range of model APIs

# Insight Agent (recommended: kimi-k2, official application: https://platform.moonshot.cn/)
INSIGHT_ENGINE_API_KEY=
INSIGHT_ENGINE_BASE_URL=
INSIGHT_ENGINE_MODEL_NAME=

# Media Agent (recommended: gemini-2.5-pro, API reseller application: https://aihubmix.com/?aff=8Ds9)
MEDIA_ENGINE_API_KEY=
MEDIA_ENGINE_BASE_URL=
MEDIA_ENGINE_MODEL_NAME=

# Query Agent (recommended: deepseek-chat, official application: https://platform.deepseek.com/)
QUERY_ENGINE_API_KEY=
QUERY_ENGINE_BASE_URL=
QUERY_ENGINE_MODEL_NAME=

# Report Agent (recommended: gemini-2.5-pro, API reseller application: https://aihubmix.com/?aff=8Ds9)
# Note: Report Agent requires relatively strong model capabilities. If the final report has blank charts or abnormal paragraphs, try switching to a more capable model
REPORT_ENGINE_API_KEY=
REPORT_ENGINE_BASE_URL=
REPORT_ENGINE_MODEL_NAME=

# MindSpider Agent (recommended: deepseek-chat, official application: https://platform.deepseek.com/)
MINDSPIDER_API_KEY=
MINDSPIDER_BASE_URL=
MINDSPIDER_MODEL_NAME=

# Forum Host (recommended: qwen-plus, official application: https://www.aliyun.com/product/bailian)
FORUM_HOST_API_KEY=
FORUM_HOST_BASE_URL=
FORUM_HOST_MODEL_NAME=

# SQL Keyword Optimizer (recommended: qwen-plus, official application: https://www.aliyun.com/product/bailian)
KEYWORD_OPTIMIZER_API_KEY=
KEYWORD_OPTIMIZER_BASE_URL=
KEYWORD_OPTIMIZER_MODEL_NAME=

# ================== WEB TOOL CONFIGURATION ====================
# Tavily API key, used for Tavily web search. Apply at: https://www.tavily.com/
TAVILY_API_KEY=

# Web search tool type, supports BochaAPI or AnspireAPI, default is AnspireAPI
SEARCH_TOOL_TYPE=AnspireAPI

# Anspire AI Search API (apply at: https://open.anspire.cn/?share_code=3E1FUOUH — half the cost of Bocha for the same results)
ANSPIRE_BASE_URL=https://plugin.anspire.cn/api/ntsearch/search
ANSPIRE_API_KEY=

# Bocha AI Search API (for Bocha multimodal search; note the key is named "Web Search" but AI Search is required, apply at: https://open.bochaai.com/)
BOCHA_BASE_URL=https://api.bocha.cn/v1/ai-search
BOCHA_WEB_SEARCH_API_KEY=